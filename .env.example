# Açar🔐 — Environment Configuration

# Database (SQLite for MVP, PostgreSQL for production)
DATABASE_URL=sqlite:///./data/relaxpanel.db

# Redis (cache, device tracking, rate limiting)
REDIS_URL=redis://redis:6379/0

# Celery (background task queue)
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Security (change to strong random string!)
SECRET_KEY=change-me-to-32-random-hex-chars-at-least

# First admin (auto-created on first boot)
FIRST_ADMIN_USERNAME=admin
FIRST_ADMIN_PASSWORD=change-this-password-immediately

# Happ Crypt integration (optional — leave empty to disable)
HAPP_API_URL=https://happ.su/api/encrypt
