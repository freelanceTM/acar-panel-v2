# Açar🔐 — Environment Configuration
# Копируйте в .env и заполните свои значения

# Database (SQLite for MVP, PostgreSQL for production)
DATABASE_URL=sqlite:///./data/relaxpanel.db

# Redis (cache, device tracking, rate limiting)
REDIS_URL=redis://redis:6379/0

# Celery (background task queue)
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Security (обязательно смените на 32+ случайных hex-символа!)
# Можно сгенерировать: openssl rand -hex 32
SECRET_KEY=change-me-to-32-random-hex-chars-at-least

# Первый админ (будет создан при первом запуске)
FIRST_ADMIN_USERNAME=admin
FIRST_ADMIN_PASSWORD=change-this-password-immediately

# Happ Crypt integration (опционально — оставьте пустым для отключения)
HAPP_API_URL=https://happ.su/api/encrypt

# Логирование (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# CORS — конкретные origins через запятую или * для всех
# В production укажите домен: https://your-domain.com
CORS_ORIGINS=*